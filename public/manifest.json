{
  "name": "AirCable",
  "short_name": "AirCable",
  "start_url": "./",
  "display": "standalone",
  "background_color": "#f2fbf5",
  "theme_color": "#2ecc71",
  "description": "Eco-friendly P2P file sharing by Cel-Ron Enterprises",
  "icons": [
    {
      "src": "logo.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "logo.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "share_target": {
    "action": "/_share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "media",
          "accept": ["image/*", "video/*", "application/pdf"]
        }
      ]
    }
  }
}
