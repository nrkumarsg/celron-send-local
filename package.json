{
  "name": "aircable-corporate-gift",
  "version": "1.0.0",
  "description": "Branded P2P file sharing gift by Cel-Ron Enterprises",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.celron.aircable",
    "productName": "AirCable",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "public/logo.png",
      "target": "portable"
    },
    "files": [
      "**/*",
      "!dist/*"
    ]
  },
  "dependencies": {
    "express": "^4.22.1",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2"
  }
}
